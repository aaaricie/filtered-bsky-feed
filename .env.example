# Bluesky credentials (needed for getPosts engagement re-fetch)
BSKY_HANDLE=parisien.cc
BSKY_APP_PASSWORD=your-app-password-here

# Feed server config
FEED_HOSTNAME=feed.parisien.cc
FEED_PORT=8000
FEED_NAME=filtered-following

# Timing
DELAY_SECONDS=300
PRUNE_HOURS=48
FOLLOWS_CACHE_TTL=3600

# Repost age decay half-life (hours)
REPOST_HALF_LIFE=6.0

# Jetstream
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
